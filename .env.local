# ─── OLTEE Platform — Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — NEVER commit it.

# ── Google Gemini API (free tier) ────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Free quota: 1,500 requests/day · No credit card required
GOOGLE_AI_API_KEY=AIzaSy-REPLACE_WITH_YOUR_KEY

# Model — gemini-2.5-flash is fast, capable, and free
GOOGLE_AI_MODEL=gemini-2.5-flash
GOOGLE_AI_MAX_TOKENS=4096

# ── App identity ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=OLTEE
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Feature flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_MONTE_CARLO=true
NEXT_PUBLIC_ENABLE_PDF_EXPORT=true
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true
NEXT_PUBLIC_MONTE_CARLO_ITERATIONS=10000
